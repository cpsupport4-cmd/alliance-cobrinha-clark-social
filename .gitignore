# Raw media — lives in Drive, not git
content/**/raw/*
!content/**/raw/.gitkeep

# Drafts — transient outputs of produce-post, regenerable. Not tracked.
# Only approved/ artifacts get committed (the audit trail of published posts).
content/[0-9]*/[0-9]*/drafts/*
!content/[0-9]*/[0-9]*/drafts/.gitkeep
!content/_template/**/drafts/.gitkeep

# Stories packs — transient daily output. Not tracked.
content/[0-9]*/stories/

# Status cache — local-only state, not version controlled
content/_status_cache.json

# Canva exports — ephemeral
content/**/exports/
content/**/*.mp4
content/**/*.mov
content/**/*.heic
content/**/*.HEIC

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor junk
.vscode/
.idea/
*.swp
*~

# Claude Code local state
.claude/local/
.claude/cache/

# Secrets (just in case)
.env
.env.local
*.key
